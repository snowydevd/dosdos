# Supabase — conseguís estos valores en app.supabase.com > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://tuproyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Para Prisma (conexión directa al postgres de Supabase)
# Se obtiene en: app.supabase.com > Settings > Database > Connection string > URI
# Asegurate de reemplazar [YOUR-PASSWORD] por tu contraseña de base de datos
DATABASE_URL=postgresql://postgres.tuproyecto:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.tuproyecto:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
